{
  "name": "openclaw-plugin-people-context",
  "version": "0.1.0",
  "description": "OpenClaw tools for a local-first people-context MCP server.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JinyangWang27/people-context.git",
    "directory": "openclaw-plugin"
  },
  "homepage": "https://github.com/JinyangWang27/people-context#readme",
  "bugs": {
    "url": "https://github.com/JinyangWang27/people-context/issues"
  },
  "keywords": [
    "openclaw",
    "clawhub",
    "mcp",
    "people-context",
    "local-first"
  ],
  "engines": {
    "node": ">=22.22.3 <23 || >=24.15.0 <25 || >=25.9.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "plugin:build": "npm run build && openclaw plugins build --entry ./dist/index.js",
    "plugin:check": "npm run build && openclaw plugins build --entry ./dist/index.js --check",
    "plugin:validate": "npm run build && openclaw plugins validate --entry ./dist/index.js",
    "test": "vitest run --config ./vitest.config.ts",
    "release:check": "npm run plugin:check && npm run plugin:validate && npm test && npm pack --dry-run"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.7.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "openclaw": "^2026.7.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "clawhubSpec": "clawhub:openclaw-plugin-people-context",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.7.1"
    },
    "compat": {
      "pluginApi": ">=2026.5.17",
      "minGatewayVersion": ">=2026.7.1"
    },
    "build": {
      "openclawVersion": "2026.7.1"
    },
    "release": {
      "publishToClawHub": true
    }
  }
}
